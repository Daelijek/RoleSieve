# See https://help.github.com/articles/ignoring-files/

############################
# Dependencies
############################
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

############################
# Next.js
############################
/.next/
/out/
/build

# Turbopack / dev cache (Next 16)
.turbo

############################
# Environment (secrets — never commit)
############################
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Allow a committed template without secrets
!.env.example

############################
# Testing & tooling
############################
/coverage
*.tsbuildinfo
.eslintcache

# Auto-generated by `next dev` / `next build`
next-env.d.ts

############################
# Deploy
############################
.vercel

############################
# Logs & debug
############################
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

############################
# OS & IDE
############################
.DS_Store
Thumbs.db
Desktop.ini
*.pem

.vscode/
.idea/
